<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Partiu Destino</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>
    <header>
        <!-- Navbar Principal -->
        <nav class="navbar navbar-expand-lg navbar-light navbar-partiu">
            <div class="container">
                <a class="navbar-brand navbar-brand-partiu" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-plane-departure"></i>
                    <span>Partiu Destino</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link nav-link-partiu" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home me-1"></i> Início
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-partiu" asp-area="" asp-controller="Home" asp-action="Privacy">
                                <i class="fas fa-info-circle me-1"></i> Sobre
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-partiu" href="#contato">
                                <i class="fas fa-envelope me-1"></i> Contato
                            </a>
                        </li>
                    </ul>
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link nav-link-partiu" asp-controller="Login" asp-action="Index">
                                <i class="fas fa-user-circle me-1"></i> Entrar
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-primary btn-sm rounded-pill px-3 ms-2" asp-controller="Cadastro" asp-action="Index">
                                <i class="fas fa-user-plus me-1"></i> Cadastrar
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer-partiu">
        <div class="container">
            <div class="footer-content">
                <!-- Coluna 1: Sobre -->
                <div class="footer-section">
                    <h5>Partiu Destino</h5>
                    <p>Sua próxima aventura começa aqui. Explore o mundo com os melhores pacotes e destinos incríveis.</p>
                    <div class="footer-redes-sociais">
                        <a href="#" title="Facebook"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" title="Instagram"><i class="fab fa-instagram"></i></a>
                        <a href="#" title="Twitter"><i class="fab fa-twitter"></i></a>
                        <a href="#" title="YouTube"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>

                <!-- Coluna 2: Links Úteis -->
                <div class="footer-section">
                    <h5>Links Úteis</h5>
                    <ul class="footer-links">
                        <li><a asp-controller="Home" asp-action="Index">Início</a></li>
                        <li><a asp-controller="Home" asp-action="Privacy">Sobre Nós</a></li>
                        <li><a href="#">Destinos</a></li>
                        <li><a href="#">Pacotes</a></li>
                        <li><a href="#">Blog</a></li>
                    </ul>
                </div>

                <!-- Coluna 3: Contato -->
                <div class="footer-section">
                    <h5>Contato</h5>
                    <p>
                        <i class="fas fa-envelope me-2"></i>
                        <a href="mailto:contato@partiudestino.com.br" style="color: rgba(255, 255, 255, 0.8); text-decoration: none;">
                            contato@partiudestino.com.br
                        </a>
                    </p>
                    <p>
                        <i class="fas fa-phone me-2"></i>
                        <a href="tel:+5511999999999" style="color: rgba(255, 255, 255, 0.8); text-decoration: none;">
                            (11) 99999-9999
                        </a>
                    </p>
                    <p>
                        <i class="fas fa-map-marker-alt me-2"></i>
                        São Paulo, SP - Brasil
                    </p>
                </div>
            </div>

            <!-- Linha de Rodapé -->
            <div class="footer-bottom">
                <p>&copy; @DateTime.Now.Year <strong>Partiu Destino</strong> - Todos os direitos reservados | Feito com <i class="fas fa-heart" style="color: #ff6b6b;"></i> para viajantes</p>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
