@model projectPartiuDestino.Models.Usuario

<div>
    <h2>Cadastro</h2>

    <form asp-controller="Cadastro" asp-action="Criar" method="post">

        <input asp-for="Nome" type="text" placeholder="Nome">

        <input asp-for="Email" type="email" placeholder="E-mail">

        <input asp-for="Senha" type="password" placeholder="Senha">

        <button type="submit">Criar Conta</button>
    </form>

    <a asp-controller="Login" asp-action="Index">
        <button type="button">Login</button>
    </a>
</div>